{
  "compilerOptions": {
    "target": "ES2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "rootDir": "../",
    "paths": {
      "@/*": [
        "./*"
      ],
      "shared/*": [
        "../shared/*"
      ],
      "@soldex/*": [
        "../*"
      ]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "types": [
      "bun-types"
    ]
  },
  "include": [
    "__tests__/**/*.ts",
    "./**/*.ts",
    "types.ts",
    "*.ts",
    "../shared/**/*.ts",
    "../shared/**/*.ttf",
    "../drizzle.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
